{
   "name": "lspt-language-support",
   "displayName": "LSPT Language Support",
   "description": "Suporte completo para a linguagem LSP (Linguagem Senior de Programação) com syntax highlighting, snippets, IntelliSense e autocomplete para 600+ funções built-in",
   "version": "1.9.0",
   "publisher": "eorgan",
   "author": {
      "name": "Eliezer Organ",
      "email": "eorgan@organ.eti.br"
   },
   "engines": {
      "vscode": "^1.60.0"
   },
   "categories": [
      "Programming Languages",
      "Snippets"
   ],
   "keywords": [
      "lspt",
      "lsp",
      "senior",
      "g5",
      "erp"
   ],
   "repository": {
      "type": "git",
      "url": "https://github.com/eorgan/LSPSenior"
   },
   "license": "MIT",
   "icon": "images/icon.png",
   "main": "./extension.js",
   "activationEvents": [
      "onLanguage:lspt",
      "onCommand:lspt.buscarFuncao",
      "onCommand:lspt.inserirCabecalho"
   ],
   "contributes": {
      "languages": [
         {
            "id": "lspt",
            "aliases": [
               "LSPT",
               "LSP",
               "Linguagem Senior de Programação"
            ],
            "extensions": [
               ".lspt",
               ".lsp"
            ],
            "configuration": "./language-configuration.json"
         }
      ],
      "grammars": [
         {
            "language": "lspt",
            "scopeName": "source.lspt",
            "path": "./syntaxes/lspt.tmLanguage.json"
         }
      ],
      "snippets": [
         {
            "language": "lspt",
            "path": "./snippets/lspt-snippets.json"
         }
      ],
      "commands": [
         {
            "command": "lspt.buscarFuncao",
            "title": "LSPT: Buscar função no catálogo",
            "category": "LSPT"
         },
         {
            "command": "lspt.inserirCabecalho",
            "title": "LSPT: Inserir cabeçalho",
            "category": "LSPT"
         }
      ],
      "configuration": {
         "title": "LSPT Language Support",
         "properties": {
            "lspt.diagnostics.enabled": {
               "type": "boolean",
               "default": true,
               "description": "Ativa avisos em tempo real das armadilhas da LSP (operação em parâmetro, Pare/Continue fora de loop)."
            },
            "lspt.diagnostics.unknownFunctions": {
               "type": "boolean",
               "default": false,
               "description": "Sinaliza chamadas a funções não encontradas no catálogo (pode gerar falso-positivo com funções do usuário/externas)."
            },
            "lspt.header.autoUpdate": {
               "type": "boolean",
               "default": true,
               "description": "Atualiza @Last Modified by/time ao salvar arquivos .lspt/.lsp."
            },
            "lspt.header.fallback.author": {
               "type": "string",
               "default": "",
               "description": "Autor usado no cabeçalho quando não há Git configurado (git config user.name)."
            },
            "lspt.header.fallback.email": {
               "type": "string",
               "default": "",
               "description": "E-mail usado no cabeçalho quando não há Git configurado (git config user.email)."
            },
            "lspt.format.indentSize": {
               "type": "integer",
               "default": 3,
               "minimum": 1,
               "maximum": 8,
               "description": "Número de espaços por nível de indentação no Format Document."
            }
         }
      }
   },
   "scripts": {
      "package": "vsce package",
      "publish": "ovsx publish"
   },
   "devDependencies": {
      "@vscode/vsce": "^2.19.0",
      "ovsx": "^0.8.0"
   }
}