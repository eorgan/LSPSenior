{
   "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
   "name": "LSPT",
   "scopeName": "source.lspt",
   "patterns": [
      {
         "include": "#comments"
      },
      {
         "include": "#definir-statements"
      },
      {
         "include": "#keywords"
      },
      {
         "include": "#system-variables"
      },
      {
         "include": "#functions"
      },
      {
         "include": "#builtin-functions"
      },
      {
         "include": "#types"
      },
      {
         "include": "#constants"
      },
      {
         "include": "#strings"
      },
      {
         "include": "#numbers"
      },
      {
         "include": "#operators"
      },
      {
         "include": "#punctuation"
      },
      {
         "include": "#variables"
      },
      {
         "include": "#webservices"
      }
   ],
   "repository": {
      "comments": {
         "patterns": [
            {
               "name": "comment.line.lspt",
               "match": "@--.*?--@"
            },
            {
               "name": "comment.line.lspt",
               "match": "@.*?@"
            },
            {
               "name": "comment.block.lspt",
               "begin": "/\\*",
               "end": "\\*/"
            }
         ]
      },
      "definir-statements": {
         "patterns": [
            {
               "match": "\\b(Definir)\\s+(Funcao|Alfa|Numero|Data|Decimal|Flutuante)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.control.definir.lspt"
                  },
                  "2": {
                     "name": "storage.type.lspt"
                  },
                  "3": {
                     "name": "entity.name.variable.lspt"
                  }
               }
            },
            {
               "match": "\\b(Definir)\\s+(interno\\.com\\.senior\\.g5\\.[a-zA-Z0-9._]+)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.control.definir.lspt"
                  },
                  "2": {
                     "name": "storage.type.lspt"
                  },
                  "3": {
                     "name": "entity.name.variable.lspt"
                  }
               }
            },
            {
               "match": "\\b(Definir)\\s+(Cursor)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.control.definir.lspt"
                  },
                  "2": {
                     "name": "storage.type.lspt"
                  },
                  "3": {
                     "name": "entity.name.variable.lspt"
                  }
               }
            }
         ]
      },
      "keywords": {
         "patterns": [
            {
               "name": "keyword.control.conditional.lspt",
               "match": "(?i)\\b(Se|Senao)\\b"
            },
            {
               "name": "keyword.control.loop.lspt",
               "match": "(?i)\\b(Enquanto|Para|Continue|Pare)\\b"
            },
            {
               "name": "keyword.control.flow.lspt",
               "match": "(?i)\\b(Cancel|Inicio|Fim|VaPara|Vapara|Regra)\\b"
            },
            {
               "name": "keyword.declaration.lspt",
               "match": "(?i)\\b(Definir|Funcao)\\b"
            },
            {
               "name": "keyword.control.import.lspt",
               "match": "(?i)\\b(Inserir)\\b"
            },
            {
               "name": "keyword.other.io.lspt",
               "match": "(?i)\\b(Abrir|Fechar|Ler|Lernl|Gravar|Gravarnl)\\b"
            },
            {
               "name": "keyword.other.lspt",
               "match": "\\b(Cursor|end|Function|RefreshFields|interno|Open|String|OpenCursor|CloseCursor|Found|NotFound)\\b"
            },
            {
               "name": "keyword.operator.word.lspt",
               "match": "(?i)\\b(E|OU|NAO)\\b"
            },
            {
               "name": "constant.language.lspt",
               "match": "(?i)\\b(ValRet|ValStr|Retorna|Erro)\\b"
            }
         ]
      },
      "types": {
         "patterns": [
            {
               "name": "entity.name.type.lspt",
               "match": "(?i)\\b(Alfa|Numero|Data|Decimal|Flutuante|Lista|Tabela|Grid)\\b"
            }
         ]
      },
      "system-variables": {
         "patterns": [
            {
               "name": "variable.language.lspt",
               "match": "(?i)\\b(AnoSis|CodEmp|CodFil|CodUsu|DatSis|DBNomeUsuario|DBTipo|DesRodape|DiaSis|Empresa|ExtSis|Filial|GerTabAlf|GerTabNum|HorSis|MesSis|NomUsu|NumPag|QtdDupPag)\\b"
            }
         ]
      },
      "builtin-functions": {
         "comment": "Gerado por scripts/build-grammar-functions.js a partir de functions.json. Não editar à mão.",
         "patterns": [
            {
               "name": "support.function.builtin.lspt",
               "match": "(?i)\\b(AbrirLog|AbrirTelaSistema|AdicionaDerivacaoModelo|AdicionaEstagioRoteiro|AdicionaItemGrid|AdicionaOperacaoManualRoteiro|AdicionaOperacaoRoteiro|AgendarExecucaoWebservice|AgendarExecucaoWebserviceEx|AgluCtbCarregar|AgluCtbContaPertence|AgluCtbContas|AgluCtbCriar|AgluCtbLibera|AlfaParaData|AlfaParaDecimal|AlteraCampoEncontroPag|AlteraCampoEncontroRec|AlteraCampoRetorno|AlteraCampoRetornoCC|AlteraCampoRetornoPE|AlteraCampoRetornoRA|AlteraCampoRetornoTF|AlteraCampoSubst|AlteraSitMccTesouraria|AlteraSitObsPed|AlterarStatusPlanoExecucao|AlterarVidaUtilBem|AnoBissexto|ApontarOPs|Arredonda|ArredondaABNT|ArredondaValorTipoAcerto|ArredondarValor|ArredondarValorEx|AssinarArquivoDigital|AtualizaConsultaPermissoes|AtualizaSaldoContabil|AtualizaSaldoContabilAbr|AtualizarPesosPFA|BaixarComponentes|BuscaAbrangenciaUsuario|BuscaCamposChaveTabela|BuscaClienteBCD|BuscaFiltroRateioFin|BuscaFiltroRateioFinSit|BuscaLinhaTexto|BuscaMascModPlano|BuscaMenorMaiorVctBaiBcd|BuscaNotasAquisicaoRural_R2055|BuscaSaldoAntCCusto|BuscaSaldoAnterior|BuscaSaldoAnteriorAbr|BuscaSaldoAnteriorAbrAux|BuscaSaldoAnteriorAbrInt|BuscaSaldoAnteriorHis|BuscaSaldoPrjFis|BuscaSaldoProjeto|BuscaTabPreco|BuscaVlrCccProduto|BuscarAbrEntUsuario|BuscarDataVencImpostoEmpresa|BuscarFilialMaiorRelevancia|BuscarSaldoContabil|CNPJValido|CPFValido|CadastrarInfAdicionaisICMS|CalculaPrecoProRata|CalcularDvNit|CaminhoMenu|CancelaSaldoOrdemCompra|CancelaSaldoRequisicoes|CancelarOP|CarregaRazaoPF|CarregaRazaoPFCCu|CarregaRazaoPFCCuSit|CarregaRazaoPFSit|CarregaSaldoAnteriorProjeto|CarregaSaldoContabil|CarregaSaldoContabilAbr|CarregaSaldoContabilAbrInt|CarregaSaldoContabilAux|CarregaSaldoContabilHis|CarregaSaldoContabilICP|CarregaSaldoContabilZer|CarregaSaldoFisPrj|CarregaSaldoProjeto|CarregarCSVparaPlataforma|CarregarImagemFundoSistema|CarregarSaldoContabil|CarregarTextoArq|ComposicaoProduto_2|ComposicaoProduto_3|Concatena|ConciliarSaldoCcu|ConsisteRelacionamentoEntreTitulos|ConvDataInt|ConverteDataBanco|ConverteDataSqlSenior2|ConverteDataToDB|ConverteParaMaiusculo|ConverteParaMinusculo|ConverteStringParaNumeroNoBanco|CopiarStr|CorrigeSaldoporDeposito|CorrigeSaldoporFilial|CriaNovaDerivacao|CriaNovoProduto|CriaNovoServico|CriarAquisicaoRural_R2055|CriarEstoque|CriarEstruturaSaldoCcu|DataExtenso|DecimalParaAlfa|DefinirCategoriaPedidoWms|DeixaNumeros|DeletarStr|DesItemLista|DesMontaData|DesmontaProduto|DiasEntreDatas|DisponibilizarPF_Faturar|DuplicarFilial|DuplicarProdutoServicoEmpresa|EntradaValor|EnviarArquivoGED|EscondeCampoTelaEntrada|EstaNulo|EstornaComponentes|ExcluiBaixaCR|ExcluiSeqModelo|ExcluirCalculoPISCOFINS|ExcluirComponenteOP|ExcluirLctoDuplicado|ExcluirLoteDuplicado|ExecutaFormularioSGI|ExecutaRegraRecursiva|ExecutaRelatorio|ExecutaRelatorioArquivo|ExecutarComandoSQL|ExecutarRotinaSapiens|ExecutarRotinaSistema|ExisteCPA501BAIFE01|ExisteVen160ProRat01|Extenso|ExtensoMes|ExtensoSemana|ForcarFimEstagioOperacao|FormataPrecisaoP|GeraItemEmbarquePedido|GeraLog|GeraMovimento|GeraMovimentoNFSaida|GeraRatOrcCtb|GerarCargaInicialOEE|GerarContaAuxiliarCliFor|GerarEntregaVarejo|GerarItensEmbalagemPFA|GerarMDFeSaidaAutomatico|GerarNumeroTicketPesagem|GerarOP|GerarOrdemRecebimentoWmsSenior|GerarOrdemSeparacaoPfNf|GerarOrdemSeparacaoWmsSenior|GerarPendenciaExportacao|GerarPendenciaExportacaoRet|GerarSubprodutosOPModelo|GerarTagCamposExtraGNRE20|GerarTagDocumentoOrigemGNRE20|GerarTagProdutoGNRE20|GerarVencimento|Gerar_Log_Analise|Gerar_Log_Generico|Gerar_Log_NotaSaida|Gerar_Log_Pedido|GravaMemListCcc|GravaNumFcc|GravaRatOrcCtb|GravaTabela|GravaUltimoNum|GravarLog|GravarNomeArquivoRelatorio|GravarObservacaoCP|GravarObservacaoCR|ImportacaoNFEletronica|IncluirComponenteOP|IncluirServicoOP|IncrementarCodigoAlfa|InsereCep|InsereParcelaPedido|InsereRateioCrp|InsereRegInt|InserirAlfa|InserirPassoPlanoExecucao|InserirStr|InsertMovimento|IntParaStr|LayoutImpGeraE615RPP|LeFaturamento|LeFaturamento2|LeGridBaixasBcd|LeMemListCcc|LeMemListCompPro|LeMemListCompPro_2|LeMemListCompPro_3|LeMemListPosEst|LeMemListProOP|LerBalanca|LerBalancaTipoPeso|LerPedidosCanSub|LerPosicaoStr|LiberaPF|LiberaPFCCu|LiberaSaldoContabil|LiberaSaldoContabilInt|LiberaSaldoProjeto|LiberarSaldoContabil|LimpaEspacos|LimpaEspacosDireita|LimpaEspacosEsquerda|LimpaGerTabAlf|LimpaGerTabNum|LimpaListSerEst|LimpaListaLotesSugeridos|LimpaListaNFCRetornoComponentes|LimpaRatOrcCtb|LimparAquisicaoRural_R2055|LimparEstruturaSaldoCcu|ListaRegraCriarLista|ListaRegraLiberarLista|LoteLctoCria|LoteLctoGeraLote|LoteLctoGeraLoteRet|LoteLctoImportacaoSapiens|LoteLctoLibera|MMCria|MMLibera|MontaAbrangencia|MontaData|MontaEstruturaProdutoOP|MontaFaturamento|MontaHistoricoPadrao|MontaListPosEst|MontaListPosEstFil|MontaListSerEst|MontaListaLotesSugeridos|MontaListaNFCRetornoComponentes|MontaSaldoAntCliTipoTitulo|MontaSaldoAntConta|MontaSaldoAntData|MontaSaldoAntForTipoTitulo|MontaSaldoAntFornecedorGrupo|MontarAutenticacaoSeniorXd|MultiplicaValor|Multiplo|NomeCompletoUsuario|ObterGuid|ObterProximoId|ObterSequenciaPendenciaCarga|ObterValorAlfaPadraoCNAB|ObterValorDataPadraoCNAB|ObterValorDecimalPadraoCNAB|ObterValorNumericoPadraoCNAB|OrcamentoCtaCtbAtualizarCtaPai|OrcamentoCtaCtbIniciarMemoria|OrcamentoCtaCtbLiberarMemoria|OrcamentoCtaCtbPreencherMemoria|OtimizarAbrangencia|PegaUltimoNum|PegarTipoVar|PegarValorVarAlf|PegarValorVarNum|PosicaoStr|Potencia|ProcuraEnter|QuebraTexto|Raiz|RecalcularOCServico|ReexecutarAcaoEletronica|RemeterRetornarServico|RetDiaSemana|RetiraAcentuacao|RetiraCaracteresEspeciais|RetornaAscII|RetornaConsiderarItemCtr|RetornaItem|RetornaItemPelaDescLista|RetornaLancamentoLista|RetornaLigacao|RetornaMensagemCadastroCliente|RetornaPrecoProRata|RetornaProximoProjeto|RetornaRegistrosLinhaADRCST|RetornarAquisicaoRural_R2055|RetornarDiasUteisMes|RetornarDiasUteisPeriodo|RetornarDigitoVerificadorVolume|RetornarParametroGlobal|RetornarParametroGlobalGoUp|RetornarQtdDiasAno|RetornarQuantidadeLoteUtilizada|RetornarSaldoCcu|RetornarSequencialBaseadoChave|RetornarSerieNotaFiscal|RetornarServicoOP|RowNum|SQLComando|SQLFechar|SQLFim|SQLNomeCampo|SQLProximo|SQLQtdCampos|SQLRetornaValor|SQLValorUnico|Saldo|SaldoAnteriorCliente|SaldoAnteriorFornecedor|SaldoContabilCompleto|SaldoInt|SaldoPF|SaldoProjeto|SalvarLog|SapiensSID|SelecaoLctCP|SelecaoTabelas|SetaAlfaTelaEntrada|SetaNumeroTelaEntrada|SetaParamBuscaTabPreco|SetarFiltroSql|SetarValorVarAlf|SetarValorVarNum|SimulacaoIMP_CR_Finalizar|SimulacaoIMP_CR_Iniciar|SimulacaoIMP_Finalizar|SimulacaoIMP_Iniciar|SinalizarCapturaPeso|SinalizarFaturamentoWmsSenior|SldCtbDefParametro|SldCtbFuncoes|SldCtbRetItemAtual|Sleep|SomarMesesDataRef|StrParaInt|SubstAlfa|SubstAlfaUmaVez|SugerirLoteCriterio|SugerirLoteUnico|TamanhoStr|TemRegistrosGrid|TotalContasCentroCusto|TotalRateado|Tracking_Cancelar|Tracking_CancelarFase|Tracking_CancelarTransferido|Tracking_RegistrarDocumento|Tracking_RegistrarFase|Tracking_Transferir|TrocaEmpresaFilial|TrocarOpcaoOperacaoOP|TruncarDecimal|TruncarValor|UltimoDia|VerificaDiaUtil|VerificaItemGrid|VerificaMovimentoConta|VerificaNumero|VerificaValor|atualizarRegIntPlataforma|integrarPlataforma)\\b"
            }
         ]
      },
      "constants": {
         "patterns": [
            {
               "name": "constant.language.lspt",
               "match": "\\b(Ler|Gravar|LerNL)\\b"
            }
         ]
      },
      "functions": {
         "patterns": [
            {
               "name": "entity.name.function.sql.lspt",
               "match": "\\b(SQL_Criar|SQL_UsarSqlSenior2|SQL_UsarAbrangencia|SQL_DefinirComando|SQL_AbrirCursor|SQL_EOF|SQL_RetornarAlfa|SQL_RetornarInteiro|SQL_RetornarFlutuante|SQL_RetornarData|SQL_Proximo|SQL_FecharCursor|SQL_Destruir)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(Mensagem|IntParaAlfa|AlfaParaInt|AlfaParaDecimal|ConverteMascara|ConverteDataBanco|MontaData|DatSis|ObterGuid|ExecSQLEx|AtualizarTabela|AtualizarCampos|Base64Encode)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(HttpObjeto|HttpPost|HttpGet|HttpLeCodigoResposta|HttpDesabilitaErroResposta|HttpAlteraCodifCaracPadrao|HttpAlteraCabecalhoRequisicao)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(SubstAlfa|PosicaoAlfa|CopiarAlfa|DeletarAlfa|LimpaEspacos|EstaNulo|VerificaNumero|RetornaAscII|RetornaValorCFG|TamanhoAlfa|TrocaString)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(Sleep|ArqExiste|Abrir|Fechar|SelecaoTabelas)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(ListaRegraCriarLista|ListaRegraCarregarJson|ListaRegraPrimeiro|ListaRegraProximo|ListaRegrafim|ListaRegraObterValorAlfa|ValorElementoJson)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(RemoveExpressoesProibidas|RestoDivisao|Truncar|VerificaAbaAtiva|VrfAbrA|VrfAbrN|EnviaEMail)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(AbrirCursor|FecharCursor|Proximo|Achou|NaoAchou)\\b"
            }
         ]
      },
      "webservices": {
         "patterns": [
            {
               "name": "support.class.lspt",
               "match": "\\b(interno\\.com\\.senior\\.g5\\.[a-zA-Z0-9._]+)\\b"
            }
         ]
      },
      "strings": {
         "patterns": [
            {
               "name": "string.quoted.double.lspt",
               "begin": "\"",
               "end": "\"",
               "patterns": [
                  {
                     "name": "constant.character.escape.lspt",
                     "match": "\\\\."
                  }
               ]
            },
            {
               "name": "string.quoted.single.lspt",
               "begin": "'",
               "end": "'",
               "patterns": [
                  {
                     "name": "constant.character.escape.lspt",
                     "match": "\\\\."
                  }
               ]
            }
         ]
      },
      "numbers": {
         "patterns": [
            {
               "name": "constant.numeric.float.lspt",
               "match": "\\b\\d+\\.\\d+\\b"
            },
            {
               "name": "constant.numeric.integer.lspt",
               "match": "\\b\\d+\\b"
            }
         ]
      },
      "operators": {
         "patterns": [
            {
               "name": "keyword.operator.comparison.lspt",
               "match": "(==|=|<>|!=|>|<|>=|<=)"
            },
            {
               "name": "keyword.operator.arithmetic.lspt",
               "match": "(\\+\\+|--|\\+|\\-|\\*|\\/|%)"
            }
         ]
      },
      "punctuation": {
         "patterns": [
            {
               "name": "punctuation.parenthesis.lspt",
               "match": "[\\(\\)]"
            },
            {
               "name": "punctuation.bracket.lspt",
               "match": "[\\[\\]]"
            },
            {
               "name": "punctuation.brace.lspt",
               "match": "[\\{\\}]"
            }
         ]
      },
      "variables": {
         "patterns": [
            {
               "name": "variable.other.lspt",
               "match": "\\b[anvdrxw][A-Z][a-zA-Z0-9_]*\\b"
            },
            {
               "name": "variable.parameter.lspt",
               "match": "\\bp[A-Z][a-zA-Z0-9_]*\\b"
            },
            {
               "name": "variable.parameter.lspt",
               "match": "\\bP[0-9]+_[A-Za-z]+\\b"
            }
         ]
      }
   }
}