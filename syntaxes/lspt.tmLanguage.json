      "constants": {
         "patterns": [
            {
               "name": "constant.language.lspt",
               "match": "\\b(Ler|Gravar|LerNL)\\b"
            }
         ]
      },
      "functions": {
         "patterns": [
            {
               "name": "entity.name.function.sql.lspt",
               "match": "\\b(SQL_Criar|SQL_UsarSqlSenior2|SQL_UsarAbrangencia|SQL_DefinirComando|SQL_AbrirCursor|SQL_EOF|SQL_RetornarAlfa|SQL_RetornarInteiro|SQL_RetornarFlutuante|SQL_RetornarData|SQL_Proximo|SQL_FecharCursor|SQL_Destruir)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(Mensagem|IntParaAlfa|AlfaParaInt|AlfaParaDecimal|ConverteMascara|ConverteDataBanco|MontaData|DatSis|ObterGuid|ExecSQLEx|AtualizarTabela|AtualizarCampos|Base64Encode)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(HttpObjeto|HttpPost|HttpGet|HttpLeCodigoResposta|HttpDesabilitaErroResposta|HttpAlteraCodifCaracPadrao|HttpAlteraCabecalhoRequisicao)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(SubstAlfa|PosicaoAlfa|CopiarAlfa|DeletarAlfa|LimpaEspacos|EstaNulo|VerificaNumero|RetornaAscII|RetornaValorCFG|TamanhoAlfa|TrocaString)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(Sleep|ArqExiste|Abrir|Fechar|SelecaoTabelas)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(ListaRegraCriarLista|ListaRegraCarregarJson|ListaRegraPrimeiro|ListaRegraProximo|ListaRegrafim|ListaRegraObterValorAlfa|ValorElementoJson)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(RemoveExpressoesProibidas|RestoDivisao|Truncar|VerificaAbaAtiva|VrfAbrA|VrfAbrN|EnviaEMail)\\b"
            },
            {
               "name": "entity.name.function.lspt",
               "match": "\\b(AbrirCursor|FecharCursor|Proximo|Achou|NaoAchou)\\b"
            }
         ]
      },
      "webservices": {
         "patterns": [
            {
               "name": "support.class.lspt",
               "match": "\\b(interno\\.com\\.senior\\.g5\\.[a-zA-Z0-9._]+)\\b"
            }
         ]
      },
      "strings": {
         "patterns": [
            {
               "name": "string.quoted.double.lspt",
               "begin": "\"",
               "end": "\"",
               "patterns": [
                  {
                     "name": "constant.character.escape.lspt",
                     "match": "\\\\."
                  }
               ]
            },
            {
               "name": "string.quoted.single.lspt",
               "begin": "'",
               "end": "'",
               "patterns": [
                  {
                     "name": "constant.character.escape.lspt",
                     "match": "\\\\."
                  }
               ]
            }
         ]
      },
      "numbers": {
         "patterns": [
            {
               "name": "constant.numeric.float.lspt",
               "match": "\\b\\d+\\.\\d+\\b"
            },
            {
               "name": "constant.numeric.integer.lspt",
               "match": "\\b\\d+\\b"
            }
         ]
      },
      "operators": {
         "patterns": [
            {
               "name": "keyword.operator.comparison.lspt",
               "match": "(==|=|<>|!=|>|<|>=|<=)"
            },
            {
               "name": "keyword.operator.arithmetic.lspt",
               "match": "(\\+\\+|--|\\+|\\-|\\*|\\/|%)"
            }
         ]
      },
      "punctuation": {
         "patterns": [
            {
               "name": "punctuation.parenthesis.lspt",
               "match": "[\\(\\)]"
            },
            {
               "name": "punctuation.bracket.lspt",
               "match": "[\\[\\]]"
            },
            {
               "name": "punctuation.brace.lspt",
