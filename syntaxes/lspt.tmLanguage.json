{
   "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
   "name": "LSPT",
   "scopeName": "source.lspt",
   "patterns": [
      {
         "include": "#comments"
      },
      {
         "include": "#definir-statements"
      },
      {
         "include": "#keywords"
      },
      {
         "include": "#system-variables"
      },
      {
         "include": "#functions"
      },
      {
         "include": "#builtin-functions"
      },
      {
         "include": "#types"
      },
      {
         "include": "#constants"
      },
      {
         "include": "#strings"
      },
      {
         "include": "#numbers"
      },
      {
         "include": "#operators"
      },
      {
         "include": "#punctuation"
      },
      {
         "include": "#variables"
      },
      {
         "include": "#webservices"
      }
   ],
   "repository": {
      "comments": {
         "patterns": [
            {
               "name": "comment.line.lspt",
               "match": "@--.*?--@"
            },
            {
               "name": "comment.line.lspt",
               "match": "@.*?@"
            },
            {
               "name": "comment.block.lspt",
               "begin": "/\\*",
               "end": "\\*/"
            }
         ]
      },
      "definir-statements": {
         "patterns": [
            {
               "match": "\\b(Definir)\\s+(Funcao|Alfa|Numero|Data|Decimal|Flutuante)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.control.definir.lspt"
                  },
                  "2": {
                     "name": "storage.type.lspt"
                  },
                  "3": {
                     "name": "entity.name.variable.lspt"
                  }
               }
            },
            {
               "match": "\\b(Definir)\\s+(interno\\.com\\.senior\\.g5\\.[a-zA-Z0-9._]+)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.control.definir.lspt"
                  },
                  "2": {
                     "name": "storage.type.lspt"
                  },
                  "3": {
                     "name": "entity.name.variable.lspt"
                  }
               }
            },
            {
               "match": "\\b(Definir)\\s+(Cursor)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
               "captures": {
                  "1": {
                     "name": "keyword.control.definir.lspt"
                  },
                  "2": {
                     "name": "storage.type.lspt"
                  },
                  "3": {
                     "name": "entity.name.variable.lspt"
                  }
               }
            }
         ]
      },
      "keywords": {
         "patterns": [
            {
               "name": "keyword.control.conditional.lspt",
               "match": "(?i)\\b(Se|Senao)\\b"
            },
            {
               "name": "keyword.control.loop.lspt",
               "match": "(?i)\\b(Enquanto|Para|Continue|Pare)\\b"
            },
            {
               "name": "keyword.control.flow.lspt",
               "match": "(?i)\\b(Cancel|Inicio|Fim|VaPara|Vapara|Regra)\\b"
            },
            {
               "name": "keyword.declaration.lspt",
               "match": "(?i)\\b(Definir|Funcao)\\b"
            },
            {
               "name": "keyword.control.import.lspt",
               "match": "(?i)\\b(Inserir)\\b"
            },
            {
               "name": "keyword.other.io.lspt",
               "match": "(?i)\\b(Abrir|Fechar|Ler|Lernl|Gravar|Gravarnl)\\b"
            },
            {
               "name": "keyword.other.lspt",
               "match": "\\b(Cursor|end|Function|RefreshFields|interno|Open|String|OpenCursor|CloseCursor|Found|NotFound)\\b"
            },
            {
               "name": "keyword.operator.word.lspt",
               "match": "(?i)\\b(E|OU|NAO)\\b"
            },
            {
               "name": "constant.language.lspt",
               "match": "(?i)\\b(ValRet|ValStr|Retorna|Erro)\\b"
            }
         ]
      },
      "types": {
         "patterns": [
            {
               "name": "entity.name.type.lspt",
               "match": "(?i)\\b(Alfa|Numero|Data|Decimal|Flutuante|Lista|Tabela|Grid)\\b"
            }
         ]
      },
      "system-variables": {
         "patterns": [
            {
               "name": "variable.language.lspt",
               "match": "(?i)\\b(AnoSis|CodEmp|CodFil|CodUsu|DatSis|DBNomeUsuario|DBTipo|DesRodape|DiaSis|Empresa|ExtSis|Filial|GerTabAlf|GerTabNum|HorSis|MesSis|NomUsu|NumPag|QtdDupPag)\\b"
            }
         ]
      },
      "builtin-functions": {
         "comment": "Gerado por scripts/build-grammar-functions.js a partir de functions.json. Não editar à mão.",
         "patterns": [
            {
               "name": "support.function.builtin.lspt",
               "match": "(?i)\\b(AbrirLog|AbrirTelaSistema|AdicionaComponenteModelo|AdicionaConsumoComponente|AdicionaDadosGrade|AdicionaDerivacaoModelo|AdicionaEstagioRoteiro|AdicionaItemGrid|AdicionaOperacaoManualRoteiro|AdicionaOperacaoRoteiro|AdicionaRateioRegra|AgendarExecucaoWebservice|AgendarExecucaoWebserviceEx|AgluCtbCarregar|AgluCtbContaPertence|AgluCtbContas|AgluCtbCriar|AgluCtbLibera|AgluCtbValorAglu|AgluCtbValorComp|AlfaParaData|AlfaParaDecimal|AlfaParaInt|AlteraCampoEncontroPag|AlteraCampoEncontroRec|AlteraCampoRetorno|AlteraCampoRetornoCC|AlteraCampoRetornoPE|AlteraCampoRetornoRA|AlteraCampoRetornoTF|AlteraCampoSubst|AlteraControle|AlteraFormaRateioTransacao|AlteraSitMccTesouraria|AlteraSitObsPed|AlteraTituloCP|AlteraValorFormula|AlterarStatusPlanoExecucao|AlterarVidaUtilBem|AnalisaBloqueioAreaPedido|AnoBissexto|ApontarOPs|ArqExiste|Arredonda|ArredondaABNT|ArredondaValorTipoAcerto|ArredondarValor|ArredondarValorEx|AssinarArquivoDigital|AtualizaBarraProgresso|AtualizaConsultaPermissoes|AtualizaEmbalagensNF|AtualizaSaldoContabil|AtualizaSaldoContabilAbr|AtualizarPesosPFA|AtualizarSituacao_PFA_PES|BaixarComponentes|Base64Decode|Base64Encode|BuscaAbrangenciaUsuario|BuscaBaixaDepreciacao|BuscaBaixaDepreciacaoTipo|BuscaCamposChaveTabela|BuscaClienteBCD|BuscaDadosInvGerAntVer|BuscaDepreciacaoAcumulada|BuscaFilialTituloCP|BuscaFiltroRateioFin|BuscaFiltroRateioFinSit|BuscaLinhaTexto|BuscaMascModPlano|BuscaMascModPlano15n|BuscaMenorMaiorVctBaiBcd|BuscaNotasAquisicaoRural_R2055|BuscaSaldoAntCCusto|BuscaSaldoAnterior|BuscaSaldoAnteriorAbr|BuscaSaldoAnteriorAbrAux|BuscaSaldoAnteriorAbrInt|BuscaSaldoAnteriorHis|BuscaSaldoPrjFis|BuscaSaldoProjeto|BuscaTabPreco|BuscaVlrCccProduto|BuscarAbrEntUsuario|BuscarDataVencImpostoEmpresa|BuscarFilialMaiorRelevancia|BuscarSaldoContabil|CNPJValido|CPFValido|CadastrarInfAdicionaisICMS|CadastrarInformacoesAdicionaisICMS|CalculaAlfa|CalculaIndiceCiap|CalculaPrecoProRata|CalculaQtdMinutos|CalcularDvNit|CalcularValoresCP|CalcularValo